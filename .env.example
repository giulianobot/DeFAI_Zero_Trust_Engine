# DeFAI Zero Trust Engine — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# xAI Grok API — for agent extraction (Workflow A & B)
XAI_API_KEY=your_xai_api_key_here

# Alchemy — BTC price, balance check, transaction broadcast
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Lit Protocol Chipotle v3 — PSBT signing via PKP wallet
LIT_API_KEY=your_lit_api_key_here

# SpacetimeDB Cloud — session state and audit data
SPACETIMEDB_URI=wss://maincloud.spacetimedb.com
SPACETIMEDB_DATABASE=your_spacetimedb_database_identity_here
